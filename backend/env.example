# NEXUS Vanguard Backend
PORT=8787

# Optional. Without this key, backend will still extract text/OCR but will not run AI extraction.
OPENAI_API_KEY=

# Recommended model. Change without touching frontend.
OPENAI_REQUIREMENT_MODEL=gpt-5.5

# Hard safety caps
MAX_UPLOAD_MB=35
AI_ENABLED=true
OCR_ENABLED=true
